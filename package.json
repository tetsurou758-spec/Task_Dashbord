{
  "name": "task-dashbord",
  "version": "0.1.0",
  "description": "個人向けタスク統合ダッシュボード（Outlook / Teams / Slack）",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "backend": "python backend/app.py",
    "build:backend": "pyinstaller backend.spec --noconfirm --distpath pybuild --workpath pybuild/work",
    "build:installer": "electron-builder",
    "dist": "npm run build:backend && npm run build:installer"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "electron": "^30.0.0",
    "jsdom": "^20.0.3"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.tetsurou.task-dashbord",
    "productName": "Task Dashbord",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "pybuild/backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "author": "tetsurou758",
  "license": "MIT"
}
